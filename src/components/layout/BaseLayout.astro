---
import "@/styles/global.css";
import { getContent, getLocaleUrls, getRestaurantSchema, normalizeLocale } from "@/data/site";

interface Props {
  lang?: string;
}

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
const localeUrls = getLocaleUrls(lang);
const schema = getRestaurantSchema(lang);
const canonical = lang === "en" ? "/" : `/${lang}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.metaTitle}</title>
    <meta name="description" content={content.metaDescription} />
    <meta property="og:title" content={content.metaTitle} />
    <meta property="og:description" content={content.metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/sushi/hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.metaTitle} />
    <meta name="twitter:description" content={content.metaDescription} />
    <meta name="theme-color" content="#07080c" />
    <link rel="canonical" href={canonical} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell card">
        <a href={lang === "en" ? "/" : `/${lang}`} class="brand-mark">
          {content.brand}
        </a>
        <div class="header-actions">
          <div class="locale-select-shell">
            <select
              class="locale-select"
              aria-label="Language"
              onchange={`window.location.href=this.value`}
            >
              {localeUrls.map((item) => (
                <option value={item.url} selected={item.active}>
                  {item.locale.toUpperCase()}
                </option>
              ))}
            </select>
          </div>
          <button type="button" class="header-ghost" onclick={`window.dispatchEvent(new CustomEvent('open-cart'))`}>
            {content.cartNav}
          </button>
          <a href="#order-menu" class="header-order">{content.orderNow}</a>
        </div>
      </div>
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    inset: 16px 16px auto;
    z-index: 30;
  }
  .header-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 999px;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.022)),
      rgba(8,10,16,.72);
  }
  .brand-mark,
  .locale-select,
  .header-order,
  .header-ghost {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .brand-mark {
    white-space: nowrap;
  }
  .header-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .locale-select-shell,
  .header-ghost {
    padding: 8px 12px;
    border-radius: 999px;
    color: rgba(246,239,230,.68);
  }
  .locale-select-shell {
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
  }
  .locale-select {
    border: 0;
    background: transparent;
    color: rgba(246,239,230,.82);
    padding-right: 14px;
    text-transform: uppercase;
    appearance: none;
  }
  .header-ghost {
    border: 0;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
  }
  .header-order {
    padding: 10px 15px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--gold), var(--gold-soft));
    color: #160f08;
  }
  @media (max-width: 860px) {
    .header-shell {
      flex-direction: column;
      align-items: stretch;
      border-radius: 28px;
    }
    .header-actions {
      justify-content: space-between;
    }
  }
</style>
