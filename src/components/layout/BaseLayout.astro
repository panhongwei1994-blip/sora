---
import "@/styles/global.css";
import { getContent, getLocaleUrls, getRestaurantSchema, normalizeLocale } from "@/data/site";

interface Props {
  lang?: string;
}

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
const localeUrls = getLocaleUrls(lang);
const schema = getRestaurantSchema(lang);
const canonical = lang === "en" ? "/" : `/${lang}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.metaTitle}</title>
    <meta name="description" content={content.metaDescription} />
    <meta property="og:title" content={content.metaTitle} />
    <meta property="og:description" content={content.metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/sushi/hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.metaTitle} />
    <meta name="twitter:description" content={content.metaDescription} />
    <meta name="theme-color" content="#07080c" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Sora Shushi" />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell card">
        <a href={lang === "en" ? "/" : `/${lang}`} class="brand-mark">
          <img src="/sushi/logo.webp" alt="Sora Sushi Logo" class="brand-logo" />
          <span>{content.brand}</span>
        </a>
        <div class="header-actions">
          <details class="locale-menu">
            <summary class="locale-trigger">
              <span>{lang.toUpperCase()}</span>
              <span class="locale-caret">▾</span>
            </summary>
            <div class="locale-popover">
              {localeUrls.map((item) => (
                <a
                  href={item.url}
                  class:list={["locale-option", { active: item.active }]}
                >
                  {item.locale.toUpperCase()}
                </a>
              ))}
            </div>
          </details>
          <button type="button" class="header-order" onclick={`window.dispatchEvent(new CustomEvent('open-cart'))`}>
            {content.cartNav}
          </button>
        </div>
      </div>
    </header>
    <slot />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }

      let deferredInstallPrompt = null;

      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
      });

      const isIosSafari = () => {
        const ua = window.navigator.userAgent;
        const isIOS = /iphone|ipad|ipod/i.test(ua);
        const isSafari = /safari/i.test(ua) && !/crios|fxios|edgios/i.test(ua);
        return isIOS && isSafari;
      };

      const isStandalone = () =>
        window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;

      const installApp = async (button) => {
        if (isStandalone()) return;

        if (deferredInstallPrompt) {
          deferredInstallPrompt.prompt();
          await deferredInstallPrompt.userChoice.catch(() => {});
          deferredInstallPrompt = null;
          return;
        }

        if (isIosSafari()) {
          window.alert(button.dataset.installIosHint || "Tap Share, then Add to Home Screen.");
          return;
        }

        window.alert(
          button.dataset.installGenericHint ||
            "Use your browser menu and choose Add to Home Screen or Install App.",
        );
      };

      document.addEventListener("click", (event) => {
        const trigger = event.target instanceof Element ? event.target.closest("[data-a2hs-trigger]") : null;
        if (!(trigger instanceof HTMLButtonElement)) return;
        event.preventDefault();
        void installApp(trigger);
      });
    </script>
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    inset: 16px 16px auto;
    z-index: 30;
  }
  .header-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 999px;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.022)),
      rgba(8,10,16,.72);
  }
  .brand-mark,
  .locale-trigger,
  .locale-option,
  .header-order {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .brand-mark {
    display: flex;
    align-items: center;
    gap: 14px;
    white-space: nowrap;
    text-decoration: none;
    color: var(--gold-soft);
  }
  .brand-logo {
    height: 42px;
    width: 42px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(212,165,74,.3);
    box-shadow: 0 10px 24px rgba(212,165,74,.22);
  }
  .header-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .locale-menu,
  .locale-trigger {
    border-radius: 999px;
    color: rgba(246,239,230,.68);
  }
  .locale-menu {
    position: relative;
  }
  .locale-trigger {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
    cursor: pointer;
  }
  .locale-trigger::-webkit-details-marker {
    display: none;
  }
  .locale-caret {
    color: rgba(244,213,154,.82);
    font-size: 11px;
  }
  .locale-popover {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 88px;
    display: grid;
    gap: 6px;
    padding: 8px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,.08);
    background:
      linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03)),
      rgba(10,12,18,.96);
    box-shadow: 0 18px 48px rgba(0,0,0,.34);
  }
  .locale-option {
    padding: 10px 12px;
    border-radius: 14px;
    color: rgba(246,239,230,.78);
    text-align: center;
  }
  .locale-option.active,
  .locale-option:hover {
    background: rgba(212,165,74,.14);
    color: var(--gold-soft);
  }
  .header-order {
    border: 0;
    padding: 8px 13px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--gold), var(--gold-soft));
    color: #160f08;
    font-size: 11px;
    letter-spacing: .18em;
  }
  @media (max-width: 860px) {
    .header-shell {
      flex-direction: row;
      align-items: center;
      border-radius: 28px;
      padding: 10px 12px;
    }
    .header-actions {
      justify-content: flex-end;
      flex-wrap: nowrap;
      min-width: 0;
    }
    .locale-popover {
      right: auto;
      left: 0;
    }
    .brand-mark {
      font-size: 11px;
      letter-spacing: .18em;
    }
    .brand-logo {
      height: 38px;
      width: 38px;
      border-radius: 10px;
    }
    .locale-trigger,
    .header-order {
      white-space: nowrap;
    }
    .locale-trigger {
      padding: 8px 12px;
    }
    .header-order {
      padding: 8px 12px;
    }
  }
</style>
